{
  "name": "palabre",
  "version": "0.11.2",
  "description": "CLI orchestrator for multi-agent AI debates and decision-making with Codex, Claude Code, OpenCode, Vibe, and Ollama.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "homepage": "https://palab.re",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JuReyms/Palabre.git"
  },
  "bugs": {
    "url": "https://github.com/JuReyms/Palabre/issues"
  },
  "keywords": [
    "ai",
    "ai-agents",
    "ai-harness",
    "ai-tools",
    "agent-orchestration",
    "cli",
    "claude",
    "codex",
    "debate-system",
    "decision-intelligence",
    "developer-tools",
    "llm",
    "multi-agent",
    "ollama",
    "opencode",
    "terminal-ui",
    "tui-app",
    "vibe",
    "orchestrator"
  ],
  "bin": {
    "palabre": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "palabre.config.example.json",
    "skills/"
  ],
  "scripts": {
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "validate:skill": "node scripts/validate_skill.mjs",
    "prepack": "pnpm validate:skill && pnpm build",
    "start": "node ./dist/index.js",
    "test": "pnpm build:test && node --test .tmp/test-dist/tests/*.test.js && pnpm test:release-social",
    "test:release-social": "node --test scripts/post_release_bluesky.test.mjs",
    "build:test": "node -e \"fs.rmSync('.tmp/test-dist',{recursive:true,force:true})\" && tsc -p tsconfig.test.json",
    "smoke:real-presets": "node -e \"fs.rmSync('.tmp/smoke-real',{recursive:true,force:true})\" && tsc --target ES2022 --module NodeNext --moduleResolution NodeNext --types node --outDir .tmp/smoke-real scripts/smoke_real_presets.ts && node .tmp/smoke-real/smoke_real_presets.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
